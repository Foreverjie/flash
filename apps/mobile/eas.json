{
  "cli": {
    "version": ">= 15.0.10",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "PROFILE": "development"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "PROFILE": "ios-simulator"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "PROFILE": "preview"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "PROFILE": "production"
      }
    }
  }
}

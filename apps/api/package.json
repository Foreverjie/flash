{
  "name": "@follow/api",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "description": "Follow API server based on Hono.js with Vercel deployment",
  "author": "Folo Team",
  "homepage": "https://github.com/RSSNext",
  "repository": {
    "url": "https://github.com/RSSNext/follow",
    "type": "git"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed:e2e": "tsx src/scripts/seed-e2e.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "dev:vercel": "vercel dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "scrape-posts": "tsx src/scripts/scrape-posts.ts",
    "seed-feeds": "tsx src/scripts/seed-feeds.ts",
    "seed-packs": "tsx src/scripts/seed-packs.ts",
    "seed-topics": "tsx src/scripts/seed-topics.ts",
    "start": "node dist/index.js",
    "sync-feeds": "tsx src/scripts/sync-feeds.ts",
    "test": "node src/scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-auth/stripe": "1.3.28",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "@mozilla/readability": "0.6.0",
    "bcrypt": "6.0.0",
    "better-auth": "1.3.28",
    "dotenv": "17.2.3",
    "drizzle-orm": "0.44.7",
    "hono": "^4.7.11",
    "linkedom": "0.18.12",
    "pathe": "2.0.3",
    "pg": "8.16.3",
    "postgres": "^3.4.5",
    "resend": "6.9.3",
    "rss-parser": "^3.13.0",
    "stripe": "19.1.0",
    "zod": "3.25.75"
  },
  "devDependencies": {
    "@types/bcrypt": "6.0.0",
    "@types/node": "24.5.2",
    "drizzle-kit": "0.31.6",
    "msw": "2.12.7",
    "tsup": "^8.3.5",
    "tsx": "4.20.6",
    "typescript": "catalog:",
    "vercel": "^39.3.0",
    "vitest": "3.2.4"
  }
}

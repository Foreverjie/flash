{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/sync-all",
      "schedule": "0 8 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}

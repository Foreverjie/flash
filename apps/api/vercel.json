{
  "version": 2,
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/cron/sync-feeds?concurrency=5&staleMinutes=50",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/scrape-enqueue?limit=100",
      "schedule": "15,45 * * * *"
    },
    {
      "path": "/api/cron/scrape-process?batchSize=5&concurrency=2",
      "schedule": "*/5 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
